---
import '../../src/styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin />
    </head>
    <body class="antialiased text-white bg-complementary">
        <div class="flex flex-col min-h-screen px-6 bg-noise sm:px-12">
            <div class="flex flex-col w-full max-w-5xl mx-auto grow">
                <nav class="flex items-center pt-6 pb-8 sm:pt-12 sm:pb-12">
                    <a href="https://atalian.be" target="_blank" rel="noopener">
                        <img src="/AtalianLogo.png" alt="Atalian" class="h-16" />
                    </a>
                </nav>
                <div class="flex gap-12 grow">
                    <aside class="hidden lg:block w-40 shrink-0">
                        <nav class="sticky top-8 text-sm space-y-1">
                            <p class="font-semibold mb-3 text-white/60 uppercase tracking-wide text-xs">Inhoud</p>
                            <a href="#het-dashboard" class="block py-1 text-white/70 hover:text-white no-underline">Het dashboard</a>
                            <a href="#melding-aanmaken" class="block py-1 text-white/70 hover:text-white no-underline">Melding aanmaken</a>
                            <a href="#service" class="block py-1 pl-3 text-white/50 hover:text-white no-underline">Service</a>
                            <a href="#storing" class="block py-1 pl-3 text-white/50 hover:text-white no-underline">Storing</a>
                            <a href="#klacht" class="block py-1 pl-3 text-white/50 hover:text-white no-underline">Klacht</a>
                            <a href="#het-meldingsformulier-invullen" class="block py-1 pl-3 text-white/50 hover:text-white no-underline">Formulier invullen</a>
                            <a href="#niet-verzonden-meldingen" class="block py-1 text-white/70 hover:text-white no-underline">Niet-verzonden meldingen</a>
                            <a href="#documenten-en-producten" class="block py-1 text-white/70 hover:text-white no-underline">Documenten en producten</a>
                            <a href="#documenten" class="block py-1 pl-3 text-white/50 hover:text-white no-underline">Documenten</a>
                            <a href="#producten" class="block py-1 pl-3 text-white/50 hover:text-white no-underline">Producten</a>
                            <a href="#werkorder-opvolgen" class="block py-1 text-white/70 hover:text-white no-underline">Werkorder opvolgen</a>
                        </nav>
                    </aside>
                    <main class="grow manual-content min-w-0">
                        <slot />
                    </main>
                    <aside class="hidden xl:flex w-36 shrink-0">
                        <div class="sticky top-8 flex flex-col items-center gap-6">
                            <a href="https://ultimo.com" target="_blank" rel="noopener">
                                <img src="/images/ultimologo.png" alt="Ultimo" class="h-12" />
                            </a>
                            <a href="https://covestro.be" target="_blank" rel="noopener">
                                <img src="/images/covestro.jpg" alt="Covestro" class="h-12" />
                            </a>
                        </div>
                    </aside>
                </div>
                <footer class="py-8 mt-12 text-sm text-white/40">
                    &copy; Atalian
                </footer>
            </div>
        </div>
    </body>
</html>
