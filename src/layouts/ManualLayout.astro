---
import '../../src/styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin />
        <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
        <script src="/pagefind/pagefind-ui.js" is:inline></script>
        <style>
            #search {
                --pagefind-ui-text: rgba(255,255,255,0.85);
                --pagefind-ui-background: rgba(255,255,255,0.08);
                --pagefind-ui-border: rgba(255,255,255,0.2);
                --pagefind-ui-tag: rgba(255,255,255,0.15);
                --pagefind-ui-primary: rgba(255,255,255,0.9);
            }
        </style>
    </head>
    <body class="antialiased text-white bg-complementary">
        <div class="flex flex-col min-h-screen bg-noise">

            <!-- Zwevende topbalk -->
            <header class="sticky top-0 z-20 bg-complementary/95 backdrop-blur border-b border-white/10 px-4 py-3">
                <div class="flex items-center justify-between max-w-screen-2xl mx-auto gap-6">
                    <a href="https://atalian.be" target="_blank" rel="noopener" class="shrink-0">
                        <img src="/AtalianLogo.png" alt="Atalian" class="h-10" />
                    </a>
                    <div class="grow">
                        <p class="font-bold text-lg leading-tight">{title}</p>
                        <p class="text-xs text-white/70 mt-0.5">
                            <strong class="text-white">Melding</strong> = aangemaakt door gebruiker &nbsp;·&nbsp;
                            <strong class="text-white">Ticket</strong> = na verzending &nbsp;·&nbsp;
                            <strong class="text-white">Job</strong> = Ultimo-term
                        </p>
                    </div>
                    <div class="flex items-center gap-6 shrink-0">
                        <a href="https://ultimo.com" target="_blank" rel="noopener">
                            <img src="/images/ultimologo.png" alt="Ultimo" class="h-8" />
                        </a>
                        <a href="https://covestro.be" target="_blank" rel="noopener">
                            <img src="/images/covestro.jpg" alt="Covestro" class="h-8" />
                        </a>
                    </div>
                </div>
            </header>

            <div class="flex flex-col w-full max-w-screen-2xl mx-auto grow px-4">
                <div class="flex gap-8 grow pt-8">
                    <aside class="hidden lg:block w-56 shrink-0">
                        <nav class="sticky top-24 text-sm space-y-1">
                            <div id="search" class="mb-4"></div>
                            <p class="font-semibold mb-3 text-white uppercase tracking-wide text-xs">Inhoud</p>
                            <a href="#het-dashboard" class="block py-1 text-white no-underline hover:opacity-70">Het dashboard</a>
                            <a href="#melding-aanmaken" class="block py-1 text-white no-underline hover:opacity-70">Melding aanmaken</a>
                            <a href="#service" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Service</a>
                            <a href="#storing" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Storing</a>
                            <a href="#klacht" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Klacht</a>
                            <a href="#het-meldingsformulier-invullen" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Formulier invullen</a>
                            <a href="#niet-verzonden-meldingen" class="block py-1 text-white no-underline hover:opacity-70">Niet-verzonden meldingen</a>
                            <a href="#documenten-en-producten" class="block py-1 text-white no-underline hover:opacity-70">Documenten en producten</a>
                            <a href="#documenten" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Documenten</a>
                            <a href="#producten" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Producten</a>
                            <a href="#werkorder-opvolgen" class="block py-1 text-white no-underline hover:opacity-70">Werkorder opvolgen</a>
                            <a href="#hoofdtabblad" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Hoofdtabblad</a>
                            <a href="#tabblad-acceptatie" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Acceptatie</a>
                            <a href="#tabblad-inspectie" class="block py-1 pl-3 text-white/80 no-underline hover:text-white">Inspectie</a>
                        </nav>
                    </aside>
                    <main class="grow manual-content min-w-0">
                        <slot />
                    </main>
                </div>
                <footer class="py-8 mt-12 text-sm text-white/40">
                    &copy; Atalian
                </footer>
            </div>
        </div>
        <script is:inline>
            window.addEventListener('DOMContentLoaded', () => {
                new PagefindUI({ element: '#search', showSubResults: false, translations: { placeholder: 'Zoeken...' } });
            });
        </script>
    </body>
</html>
